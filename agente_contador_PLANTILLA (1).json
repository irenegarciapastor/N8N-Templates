      "parameters": {
        "jsCode": "const d = $('Filtrar y calcular datos').first().json;\n\nconst catTexto = Object.entries(d.porCategoria)\n  .sort((a,b) => b[1]-a[1])\n  .map(([cat, val]) => `  • ${cat}: ${parseFloat(val).toFixed(2)} €`)\n  .join('\\n');\n\nconst texto = `📊 *Resumen financiero · ${d.periodo}*\n\n💶 *Total gastado:* ${parseFloat(d.totalGastado).toLocaleString('es-ES', {minimumFractionDigits:2})} €\n🧾 *Facturas procesadas:* ${d.totalFacturas}\n\n📂 *Gasto por categoría:*\n${catTexto}\n\n🏢 *Top proveedores:*\n${d.top5Proveedores.map(([p,v]) => `  • ${p}: ${parseFloat(v).toFixed(2)} €`).join('\\n')}`;\n\nreturn [{ json: { texto } }];"
      },
