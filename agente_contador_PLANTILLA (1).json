      "id": "08014979-710b-4072-9058-7c65083087f1",
      "name": "Leer Sheet facturas",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        720,
        224
      ]
    },
    {
      "parameters": {
        "jsCode": "const mensaje = $('Telegram Trigger').first().json.message.text.toLowerCase();\n\nconst meses = {\n  enero:1, febrero:2, marzo:3, abril:4, mayo:5, junio:6,\n  julio:7, agosto:8, septiembre:9, octubre:10, noviembre:11, diciembre:12\n};\n\nconst mesesNombres = ['enero','febrero','marzo','abril','mayo','junio',\n  'julio','agosto','septiembre','octubre','noviembre','diciembre'];\n\nconst añoMatch = mensaje.match(/\\d{4}/);\nconst año = añoMatch ? parseInt(añoMatch[0]) : null;\n\nlet mes = null;\nfor (const [nombre, num] of Object.entries(meses)) {\n  if (mensaje.includes(nombre)) { mes = num; break; }\n}\n\n// Parser para \"14 de abril de 2023\"\nfunction parsearFecha(str) {\n  if (!str) return null;\n  // Formato \"14 de abril de 2023\"\n  const textMatch = str.match(/(\\d{1,2}) de (\\w+) de (\\d{4})/i);\n  if (textMatch) {\n    const dia = parseInt(textMatch[1]);\n    const mesNum = meses[textMatch[2].toLowerCase()];\n    const añoNum = parseInt(textMatch[3]);\n    if (mesNum) return new Date(añoNum, mesNum - 1, dia);\n  }\n  // Formato YYYY-MM-DD como fallback\n  const isoMatch = str.match(/^(\\d{4})-(\\d{2})-(\\d{2})$/);\n  if (isoMatch) return new Date(parseInt(isoMatch[1]), parseInt(isoMatch[2])-1, parseInt(isoMatch[3]));\n  return null;\n}\n\nconst filas = $input.all().map(i => i.json);\n\nconst filtradas = filas.filter(f => {\n  const fecha = parsearFecha(f.fecha);\n  if (!fecha || isNaN(fecha)) return false;\n  const coincideAño = año ? fecha.getFullYear() === año : true;\n  const coincideMes = mes ? (fecha.getMonth() + 1) === mes : true;\n  return coincideAño && coincideMes;\n});\n\nconst totalGastado = filtradas.reduce((acc, f) => acc + (parseFloat(f.total) || 0), 0);\n\nconst porCategoria = {};\nfiltradas.forEach(f => {\n  const cat = f['categorías'] || f['categorias'] || 'Sin categoría';\n  porCategoria[cat] = (porCategoria[cat] || 0) + (parseFloat(f.total) || 0);\n});\n\nconst porProveedor = {};\nfiltradas.forEach(f => {\n  const prov = f.proveedor || 'Desconocido';\n  porProveedor[prov] = (porProveedor[prov] || 0) + (parseFloat(f.total) || 0);\n});\nconst top5Proveedores = Object.entries(porProveedor)\n  .sort((a,b) => b[1]-a[1])\n  .slice(0,5);\n\nconst porMes = {};\nfiltradas.forEach(f => {\n  const fecha = parsearFecha(f.fecha);\n  if (!fecha) return;\n  const m = fecha.getMonth() + 1;\n  porMes[m] = (porMes[m] || 0) + (parseFloat(f.total) || 0);\n});\n\nconst periodoTexto = mes\n  ? `${mesesNombres[mes-1].charAt(0).toUpperCase() + mesesNombres[mes-1].slice(1)} ${año || ''}`\n  : `Año ${año}`;\n\nreturn [{\n  json: {\n    periodo: periodoTexto,\n    totalFacturas: filtradas.length,\n    totalGastado: totalGastado.toFixed(2),\n    porCategoria,\n    top5Proveedores,\n    porMes\n  }\n}];"
      },
      "id": "d364067e-27a9-40e6-8012-02ff7f129f4b",
      "name": "Filtrar y calcular datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        224
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\nconst categoriasLabels = JSON.stringify(Object.keys(d.porCategoria));\nconst categoriasData = JSON.stringify(Object.values(d.porCategoria).map(v => parseFloat(v).toFixed(2)));\n\nconst provLabels = JSON.stringify(d.top5Proveedores.map(p => p[0]));\nconst provData = JSON.stringify(d.top5Proveedores.map(p => parseFloat(p[1]).toFixed(2)));\n\nconst mesesNombres = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];\nconst mesesLabels = JSON.stringify(Object.keys(d.porMes).map(m => mesesNombres[m-1]));\nconst mesesData = JSON.stringify(Object.values(d.porMes).map(v => parseFloat(v).toFixed(2)));\n\nconst html = `<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\"><\\/script>\n<style>\n  body { font-family: Arial, sans-serif; background: #0f172a; color: white; padding: 24px; width: 900px; margin: 0; }\n  h1 { text-align: center; color: #38bdf8; font-size: 22px; margin-bottom: 20px; }\n  .kpi { display: flex; gap: 20px; justify-content: center; margin-bottom: 24px; }\n  .kpi-box { background: #1e293b; border-radius: 12px; padding: 16px 32px; text-align: center; }\n  .kpi-box .valor { display: block; font-size: 28px; font-weight: bold; color: #38bdf8; }\n  .kpi-box .label { display: block; font-size: 12px; color: #94a3b8; margin-top: 4px; }\n  .graficos { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }\n  .grafico-box { background: #1e293b; border-radius: 12px; padding: 16px; }\n  .grafico-box h3 { font-size: 13px; color: #94a3b8; margin: 0 0 12px 0; }\n  .full-width { grid-column: span 2; }\n<\\/style>\n<\\/head>\n<body>\n<h1>📊 Dashboard Financiero · ${d.periodo}<\\/h1>\n<div class=\"kpi\">\n  <div class=\"kpi-box\">\n    <span class=\"valor\">${parseFloat(d.totalGastado).toLocaleString('es-ES', {minimumFractionDigits:2})} €<\\/span>\n    <span class=\"label\">Total gastado<\\/span>\n  <\\/div>\n  <div class=\"kpi-box\">\n    <span class=\"valor\">${d.totalFacturas}<\\/span>\n    <span class=\"label\">Facturas procesadas<\\/span>\n  <\\/div>\n<\\/div>\n<div class=\"graficos\">\n  <div class=\"grafico-box\">\n    <h3>Gasto por categoría<\\/h3>\n    <canvas id=\"cat\"><\\/canvas>\n  <\\/div>\n  <div class=\"grafico-box\">\n    <h3>Top 5 proveedores<\\/h3>\n    <canvas id=\"prov\"><\\/canvas>\n  <\\/div>\n  <div class=\"grafico-box full-width\">\n    <h3>Evolución mensual<\\/h3>\n    <canvas id=\"meses\"><\\/canvas>\n  <\\/div>\n<\\/div>\n<script>\nconst colores = ['#38bdf8','#818cf8','#34d399','#fb923c','#f472b6','#facc15','#a78bfa'];\nnew Chart(document.getElementById('cat'), {\n  type: 'doughnut',\n  data: { labels: ${categoriasLabels}, datasets: [{ data: ${categoriasData}, backgroundColor: colores }] },\n  options: { plugins: { legend: { labels: { color: 'white', font: { size: 11 } } } } }\n});\nnew Chart(document.getElementById('prov'), {\n  type: 'bar',\n  data: { labels: ${provLabels}, datasets: [{ data: ${provData}, backgroundColor: '#38bdf8', borderRadius: 6 }] },\n  options: { indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { ticks: { color: 'white' }, grid: { color: '#334155' } }, y: { ticks: { color: 'white' }, grid: { color: '#334155' } } } }\n});\nnew Chart(document.getElementById('meses'), {\n  type: 'line',\n  data: { labels: ${mesesLabels}, datasets: [{ data: ${mesesData}, borderColor: '#38bdf8', backgroundColor: 'rgba(56,189,248,0.15)', fill: true, tension: 0.4, pointBackgroundColor: '#38bdf8' }] },\n  options: { plugins: { legend: { display: false } }, scales: { x: { ticks: { color: 'white' }, grid: { color: '#334155' } }, y: { ticks: { color: 'white' }, grid: { color: '#334155' } } } }\n});\n<\\/script>\n<\\/body>\n<\\/html>`;\n\nreturn [{ json: { html } }];"
      },
      "id": "ac3bfdfe-6485-4c23-a6c1-547b4a2ec8bf",
      "name": "Generar HTML dashboard",
