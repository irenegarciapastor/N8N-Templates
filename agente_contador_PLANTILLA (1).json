        16
      ],
      "id": "120c24d3-31d6-4f70-94c3-352584cc6afc",
      "name": "Analyze image"
    },
    {
      "parameters": {
        "jsCode": "let raw = $json.text || $json.output || $json.content || '';\n// Limpia posibles fences accidentalmente devueltos\nraw = raw.replace(/^```json\\s*/i, '').replace(/```$/i, '').trim();\n\n// Si vino envuelto como [{\"content\":\"...\"}]\nif (!raw && Array.isArray(items) && items[0]?.json?.content) {\n  raw = items[0].json.content.replace(/^```json\\s*/i, '').replace(/```$/i, '').trim();\n}\n\nlet d;\ntry {\n  d = JSON.parse(raw);\n} catch (e) {\n  // Fallback: intenta extraer el primer objeto {...}\n  const m = raw.match(/\\{[\\s\\S]*\\}/);\n  if (!m) throw new Error('No JSON found in LLM output');\n  d = JSON.parse(m[0]);\n}\n\nreturn [{ json: d }];"
      },
